# State — runtime data, never commit
state/
*.db
*.db-wal
*.db-shm
*.log

# SSL certs and keys — NEVER commit
*.p12
*.key
*.crt
*.csr
*.srl
*.cnf
ssl/

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Xcode
ios/*/DerivedData/
ios/*/*.xcuserdata
ios/*/*.xcworkspace/xcuserdata/
ios/*/build/

# macOS
.DS_Store
*.swp
*~

# Environment
.env
.env.*

# Personal / internal docs (not for OSS distribution)
server/launch_dana.sh
docs/OSS_PLAN.md

# Runtime artifacts
nohup.out

# Generated state (created by setup.py and server runtime)
state/*.db
state/*.log
state/ssl/
state/backups/
state/embeddings/
state/uploads/
state/config.json

# Screenshots (keep local, not for OSS)
screenshots/
